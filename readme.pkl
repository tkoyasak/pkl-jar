/// PKL packages published to `pkg.pkl-lang.org`.
module readme

local allPklProjects = import*("[!.]*/PklProject")

output {
  text =
    """
    # pkl-jar

    <!-- Generated by `readme.pkl`. Run `pkl eval readme.pkl -o README.md` to update. -->

    PKL packages published to [`pkg.pkl-lang.org`](https://pkl-lang.org/package-docs/).

    ## Packages

    | Package | Version | Description |
    | ------- | ------- | ----------- |
    \(allPklProjects.toMap().values.map((pkg) ->
      "| [`\(pkg.package.name)`](\(pkg.package.sourceCode)) | \(pkg.package.version) | \(pkg.package.description) |"
    ).join("\n"))
    """
}
